# AgriPulse FMIS Configuration

# Sensor mode: "simulated" (default) or "real" (requires Raspberry Pi hardware)
SENSOR_MODE=simulated

# Database URL (default: SQLite)
DATABASE_URL=sqlite:///./agripulse.db

# For PostgreSQL, use:
# DATABASE_URL=postgresql://user:password@localhost:5432/agripulse

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Server Configuration
HOST=0.0.0.0
PORT=8000
